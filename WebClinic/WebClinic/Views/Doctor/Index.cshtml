@model IEnumerable<WebClinic.Data.ViewModels.Doctor.DoctorViewModel>

@{
    ViewData["Title"] = "Список врачей";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a href="@Url.Action("Create", "Doctor")" class="btn btn-primary">Создать нового врача</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Фамилия</th>
            <th>Имя</th>
            <th>Отчество</th>
            <th>Почта</th>
            <th>Должность</th>
            <th>Стаж</th>
            <th>Зарплата</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var doctor in Model)
        {
            <tr>
                <td>@doctor.LastName</td>
                <td>@doctor.FirstName</td>
                <td>@doctor.MiddleName</td>
                <td>@doctor.Email</td>
                <td>@doctor.PostName</td>
                <td>@doctor.Experience лет</td>
                <td>@doctor.Salary ₽</td>
                <td>
                    <a href="@Url.Action("Edit", "Doctor", new { id = doctor.Id })" class="btn btn-warning btn-sm">Редактировать</a>
                    <a href="@Url.Action("Delete", "Doctor", new { id = doctor.Id })" class="btn btn-danger btn-sm" onclick="return confirm('Вы уверены, что хотите удалить этого врача?');">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
