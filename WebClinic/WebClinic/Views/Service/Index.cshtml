@model IEnumerable<WebClinic.Data.ViewModels.Service.ServiceViewModel>

@{
    ViewData["Title"] = "Список услуг";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a href="@Url.Action("Create", "Service")" class="btn btn-primary">Создать новую услугу</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Наименование</th>
            <th>Описание</th>
            <th>Кабинет</th>
            <th>Стоимость</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var service in Model)
        {
            <tr>
                <td>@service.ServiceName</td>
                <td>@service.Description</td>
                <td>@service.Cabinet</td>
                <td>@service.Cost</td>
                <td>
                    <a href="@Url.Action("Edit", "Service", new { id = service.Id })" class="btn btn-warning btn-sm">Редактировать</a>
                    <a href="@Url.Action("Delete", "Service", new { id = service.Id })" class="btn btn-danger btn-sm">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
